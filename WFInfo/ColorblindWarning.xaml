<Window x:Class="WFInfo.ColorblindWarning"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WFInfo"
        mc:Ignorable="d"
        Title="Colorblind Filters Detected" Height="175" Width="440" BorderBrush="#FF707070" WindowStyle="None" ResizeMode="NoResize">
    <Window.Resources>

    </Window.Resources>
    <Grid Background="#FF1B1B1B" MouseDown="MouseDown">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="27"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="27"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Rectangle Stroke="#FF707070" Grid.ColumnSpan="3" Grid.RowSpan="2"/>
        <Rectangle Stroke="#FF646464" Fill="#FF0F0F0F" Grid.ColumnSpan="3"/>
        <Image Margin="2,0,2,2" Source="Resources/WFLogo.png" >
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.25"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <TextBlock x:Name="TitleText" Text="Colorblind Filters Detected" Margin="7,3,0,0" Background="{x:Null}" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16" FontFamily="{StaticResource Roboto_Black}" Grid.Column="1" Height="19" />
        <Label MouseLeftButtonDown="Exit" Content="x" Style="{StaticResource Label_Button}" Margin="0,0,0,0" Grid.Column="2"/>
        <StackPanel Grid.ColumnSpan="3" Grid.Row="1" Margin="12,10,12,10">
            <TextBlock TextWrapping="Wrap"
                       Text="Warframe has colorblind filters enabled, which changes the in-game colors WFInfo relies on for theme detection. For accurate results, configure a Custom theme using the calibration guide."/>
            <TextBlock Margin="0,6,0,0">
                <Hyperlink NavigateUri="https://wfinfo.warframestat.us/#themeAdjuster" RequestNavigate="Hyperlink_RequestNavigate">
                    Open Calibration Guide
                </Hyperlink>
            </TextBlock>
            <Label MouseLeftButtonDown="Dismiss" ToolTip="Close this notification" Content="Dismiss" Style="{StaticResource Label_Button}" Margin="0,10,0,4" Padding="0,0,0,1" HorizontalAlignment="Center" Width="80" Height="26"/>
        </StackPanel>
    </Grid>
</Window>
